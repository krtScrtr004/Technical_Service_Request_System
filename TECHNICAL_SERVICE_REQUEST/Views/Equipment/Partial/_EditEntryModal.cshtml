@model TECHNICAL_SERVICE_REQUEST.Models.EquipmentFormViewModel
@using TECHNICAL_SERVICE_REQUEST.Core

@{
    ViewBag.Title = "Edit";

    var id = Model.Id.ToString();
    var assetTag = Model.AssetTag.Trim();
    var model = Model.Model.Trim();
}

<section id="edit_equipment_entry_modal" class="modal fade" role="dialog">
    <section class="modal-dialog">

        @* Modal content *@
        <section class="modal-content">

            @* Header *@
            <section class="modal-header bg-primary">
                <button type="button" class="close" data-dismiss="modal">&times;</button>

                <h4 class="modal-title text-light">
                    <i class="glyphicon glyphicon-list-alt text-light"></i>
                    @(model) - (@(assetTag))
                </h4>
            </section>

            @using (Html.BeginForm(
                "Edit",
                "Equipment",
                new { id = id },
                FormMethod.Post,
                new { @class = "flex-col flex-1" }
            ))
            {
                Html.RenderPartial("~/Views/Equipment/Partial/_CreateEditForm.cshtml", Model);

                <section class="equipment-form-actions text-right flex-row-reverse flex-child-center-h">
                    <button type="submit" class="btn btn-m btn-primary bold-text">
                        <i class="glyphicon glyphicon-floppy-disk"></i>
                        Save
                    </button>
                </section>
            }

        </section>

    </section>
</section>

