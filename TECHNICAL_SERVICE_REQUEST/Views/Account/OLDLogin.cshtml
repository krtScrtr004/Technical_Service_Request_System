
@model TECHNICAL_SERVICE_REQUEST.Models.LoginViewModel

@{
    ViewBag.Title = "Log in";
}

<div class="container-fluid" style="height:100vh; padding-top:50px; ">

    <div class="col-md-1"></div>

    <div class="col-md-9">

        <center>
            <img src="~/Content/Images/logo.png" style="width:13em;" />
        </center>

        <br />

        <center>
            <h5>
                DEPARTMENT OF HEALTH <br />METRO MANILA CENTER FOR HEALTH DEVELOPMENT
            </h5>

            <h2>TECHNICAL SERVICE REQUEST SYSTEM</h2>

        </center>

        <br />

        @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }))
        {
            @Html.AntiForgeryToken()

            <center>

                @if (Model != null && Model.Alert != null && Model.Alert.ContainsKey("invalidLogin"))
                {
                    <div class="alert alert-danger" style="width:100%;">
                        @Model.Alert["invalidLogin"].Message
                    </div>
                }

                <div class="form-group">
                    @Html.TextBoxFor(m => m.Email, new {
                   @class = "form-control",
                   @placeholder = "EMAIL",
                   style = "height:40px; width:300px; font-size:14px;"
               })
                </div>

                <div class="form-group">
                    @Html.PasswordFor(m => m.Password, new {
                      @class = "form-control",
                       @placeholder = "PASSWORD",
                        style = "height:40px; width:300px; font-size:14px;"
    })
                </div>


                <div class="form-group">
                    <input type="submit" value="Log in"
                           class="btn"
                           style="width:300px; height:40px; font-size17px; background-color:#009688; color:white;" />
                </div>

                <div class="form-group">
                    <label>
                        @Html.CheckBoxFor(m => m.RememberMe) Remember Me
                    </label>
                </div>

                <a href="@Url.Action("Create", "RegistrationRequest")"
                   style="color:#00a65a; font-size:14px; font-weight:500; text-decoration:none;">
                    Register as a new user
                </a>

            </center>
        }
    </div>

    <div class="col-md-3"></div>
</div>