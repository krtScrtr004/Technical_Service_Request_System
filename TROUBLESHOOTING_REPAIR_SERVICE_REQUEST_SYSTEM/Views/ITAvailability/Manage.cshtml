@model TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Models.ITAvailabilityManageViewModel
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Core

@{
    ViewBag.Title = "Manage";

    var currentUser = ViewBag.CurrentUser as UserSession;
}

@section Styles {
    <link rel="stylesheet" href="~/Content/App/ITAvailability/Manage.css" type="text/css" />
}

<section class="container availaibility-container flex-row flex-wrap">

    <section class="content-panel panel panel-default">
        <section class="panel-heading">
            <h4>
                <i class="glyphicon glyphicon-calendar"></i>
                SCHEDULE AVAILABILITY MANAGEMENT
            </h4>

            <p>
                You can use the calendar below to select the dates you are unavailable for work. Once you are done, click the "Save Changes" button to update your schedule.
            </p>
        </section>

        <section class="content-panel-body panel-body flex-row flex-wrap">
            <section>
                @Html.AntiForgeryToken()
                @Html.HiddenFor(model => model.SelectedStringDates, new { id = "preloaded_blocked_dates" })

                @* Calendar *@
                <div class="input-group date" id="datetime_picker"></div>
            </section>

            <section class="selected-date-badge-container flex-col">
                <div class="flex-row flex-wrap">
                    @* Badges Here *@
                </div>

                <section class="buttons-container flex-col flex-child-end-v">
                    <hr class="bg-default" />

                    <div class="buttons flex-row-reverse flex-wrap">
                        <button id="modify_availability_button" type="button" class="btn btn-primary btn-sm">
                            <i class="glyphicon glyphicon glyphicon-floppy-disk"></i>
                            Save Changes
                        </button>

                        <a href="/" class="btn btn-danger btn-sm">
                            <i class="glyphicon glyphicon glyphicon-remove"></i>
                            Cancel
                        </a>
                    </div>
                </section>

            </section>

        </section>
    </section>

    <section class="container availability-history-container bg-light panel">
        <section class="">
            <div>
                <h4 class="text-primary">
                    <i class="glyphicon glyphicon-time"></i>
                    History
                </h4>

                <p class="text-default">You may view your availability history below.</p>
            </div>

            <div class="history-selects-container flex-row flex-wrap">

                <div class="form-group">
                    <label for="history_year_select">Year:</label>
                    <select id="history_year_select" class="form-control input-sm"></select>
                </div>

                <div class="form-group">
                    <label for="history_month_select">Month:</label>
                    <select id="history_month_select" class="form-control input-sm"></select>
                </div>

            </div>

            <div id="history_calendar_container"></div>
        </section>
    </section>

</section>

@section Scripts {
    <script>
        const registrationYear = "@Model.UserRegistrationDate.Year";
        const submitUrl = "@Url.Action("Manage", "ITAvailability", new { id = currentUser.Id })";
        const getBlockedDatesUrl = "@Url.Action("GetBlockedDates", "ITAvailability")";
    </script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.10.0/js/bootstrap-datepicker.min.js"></script>
    <script type="module" src="~/Scripts/App/ITAvailability/InitializeDatetimePicker.js" defer></script>
    <script type="module" src="~/Scripts/App/ITAvailability/SaveChanges.js" defer></script>
    <script type="module" src="~/Scripts/App/ITAvailability/InitializeHistory.js" defer></script>
}

