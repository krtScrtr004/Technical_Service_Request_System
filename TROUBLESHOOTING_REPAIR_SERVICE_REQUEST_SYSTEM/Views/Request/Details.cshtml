@model TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Models.RequestDetailsViewModel
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Enumerables;
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Utilities;
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Core;

@{
    ViewBag.Title = "Details";

    var currentUser = ViewBag.CurrentUser as UserSession;
    var userAccountType = currentUser.RoleId;

    var isStandard = AccountTypeEnum.IsStandard(userAccountType);
    var isAdmin = AccountTypeEnum.IsAdmin(userAccountType);
    var isIT = AccountTypeEnum.IsIT(userAccountType);

    var currentStatus = Model.StatusId;

    var isQueued = ViewBag.IsQueued as bool? ?? false;

    var statusId = Model.StatusId;
    var statusName = RequestStatusEnum.DisplayName(Model.StatusId);

    var isFormGeneratable = currentStatus == (int)RequestStatusEnum.RESOLVED ||
        currentStatus == (int)RequestStatusEnum.CLOSED;
    var generateTsrfButtonClass = isFormGeneratable ? "block" : "no-display";
    var formLink = isFormGeneratable ?
        Url.Action("Form", "Request", new { id = Model.FormGeneratableHistoryId })
        : "#";

    var isOwnRequest = Model.ClientId == currentUser.Id;
    var isEditable = isStandard && isOwnRequest &&
        (currentStatus == (int)RequestStatusEnum.PENDING ||
        currentStatus == (int)RequestStatusEnum.OPEN);

    var isImmutable = currentStatus == (int)RequestStatusEnum.CANCELLED ||
        currentStatus == (int)RequestStatusEnum.CLOSED;
    var isCancellable = RequestStatusEnum
        .GetCancellableStatusIds()
        .Any(s => s == currentStatus);

    var isEquipmentRepairTroubleshootingService = Model.TypeId.GetValueOrDefault() == (int)RequestTypeEnum.EQUIPMENT_REPAIR_TROUBLESHOOTING;
    var hasEquipmentDetails = (!string.IsNullOrEmpty(Model.EquipmentModel) ||
        !string.IsNullOrEmpty(Model.EquipmentAssetTag) ||
        !string.IsNullOrEmpty(Model.EquipmentTypeName));

    var isScheduledService = RequestTypeEnum.IsScheduleControlProcessRequest(Model.TypeId.GetValueOrDefault());
    var hasScheduleDetails = Model.ScheduledDate.HasValue &&
        Model.ScheduledStartTime.HasValue &&
        Model.ScheduledEndTime.HasValue;

    Func<int, string> getStatusLabelClass = (status) =>
    {
        switch (status)
        {
            case RequestStatusEnum.PENDING:
                return "label label-warning status-label";
            case RequestStatusEnum.OPEN:
                return "label label-primary status-label";
            case RequestStatusEnum.ONGOING:
                return "label label-info status-label";
            case RequestStatusEnum.RESOLVED:
                return "label label-success status-label";
            case RequestStatusEnum.CANCELLED:
                return "label label-danger status-label";
            case RequestStatusEnum.CLOSED:
                return "label label-default status-label";
            default:
                return "label label-default status-label";
        }
    };

    Func<int, string> getSeverityLabelClass = (severity) =>
    {
        switch (severity)
        {
            case RequestSeverityEnum.LOW:
                return "label label-success";
            case RequestSeverityEnum.MEDIUM:
                return "label label-warning";
            case RequestSeverityEnum.HIGH:
            case RequestSeverityEnum.CRITICAL:
                return "label label-danger";
            default:
                return "label label-default";
        }
    };
}

@section Styles {
    <link rel="stylesheet" href="~/Content/App/Request/Details.css" />
}

@Html.AntiForgeryToken()

<section class="container tsr-detail-page-container">
    <section class="panel panel-default tsr-content-panel">

        @* Heading *@
        <section class="panel-heading tsr-page-header flex-row flex-child-center-h flex-space-between flex-wrap">
            <div class="tsr-page-header-main">
                <p class="tsr-ref-code text-primary">REFERENCE CODE: @Model.ReferenceCode</p>

                <div id="status_container" class="tsr-page-status">
                    <span class="@getStatusLabelClass(statusId)">
                        @statusName
                    </span>
                </div>
            </div>

            <div class="tsr-page-actions flex-row flex-wrap">
                <a id="generate_tsrf_button" class="btn btn-success @generateTsrfButtonClass" href="@formLink">
                    <i class="glyphicon glyphicon-file"></i>
                    Generate TSRF
                </a>
            </div>
        </section>

        @* Body *@
    <section class="panel-body tsr-page-body">

        @{
            var clientLastName = Model.ClientLastName.Trim();
            var clientFirstName = Model.ClientFirstName.Trim();
            var clientMiddleName = !string.IsNullOrWhiteSpace(Model.ClientMiddleName)
                ? Model.ClientMiddleName.Trim()
                : "N/A";
            var clientExtensionName = !string.IsNullOrWhiteSpace(Model.ClientExtensionName)
                ? Model.ClientExtensionName.Trim()
                : "N/A";
            var clientEmail = !string.IsNullOrWhiteSpace(Model.ClientEmailAddress)
                    ? Model.ClientEmailAddress.Trim()
                    : "N/A";
            var clientContactNumber = !string.IsNullOrWhiteSpace(Model.ClientContactNumber)
                    ? Model.ClientContactNumber.Trim()
                    : "N/A";
            var clientOffice = !string.IsNullOrWhiteSpace(Model.ClientOffice)
                ? Model.ClientOffice.Trim()
                : "N/A";
            var clientPosition = !string.IsNullOrWhiteSpace(Model.ClientPosition)
                ? Model.ClientPosition.Trim()
                : "N/A";
        }

        @* Client Information *@
        <section class="tsr-detail-section">
            <div class="tsr-detail-section-header">
                <h4 class="section-heading-title text-primary">
                    <i class="glyphicon glyphicon-user"></i>
                    CLIENT INFORMATION
                </h4>
            </div>

            <div class="tsr-detail-grid tsr-detail-grid-3">
                <div class="tsr-detail-item">
                    <p class="tsr-detail-label light-text">LAST NAME</p>
                    <p class="tsr-detail-value">@clientLastName</p>
                </div>

                <div class="tsr-detail-item">
                    <p class="tsr-detail-label light-text">FIRST NAME</p>
                    <p class="tsr-detail-value">@clientFirstName</p>
                </div>

                <div class="tsr-detail-item">
                    <p class="tsr-detail-label light-text">MIDDLE NAME</p>
                    <p class="tsr-detail-value">@(clientMiddleName ?? "N/A")</p>
                </div>

                <div class="tsr-detail-item">
                    <p class="tsr-detail-label light-text">EXT. NAME</p>
                    <p class="tsr-detail-value">@(clientExtensionName ?? "N/A")</p>
                </div>

                <div class="tsr-detail-item">
                    <p class="tsr-detail-label light-text"><i class="glyphicon glyphicon-envelope"></i> EMAIL</p>
                    <p class="tsr-detail-value">@clientEmail</p>
                </div>

                <div class="tsr-detail-item">
                    <p class="tsr-detail-label light-text"><i class="glyphicon glyphicon-earphone"></i> CONTACT NUMBER</p>
                    <p class="tsr-detail-value">@clientContactNumber</p>
                </div>

                <div class="tsr-detail-item">
                    <p class="tsr-detail-label light-text">OFFICE</p>
                    <p class="tsr-detail-value">@clientOffice</p>
                </div>

                <div class="tsr-detail-item">
                    <p class="tsr-detail-label light-text">POSITION</p>
                    <p class="tsr-detail-value">@clientPosition</p>
                </div>
            </div>
        </section>

        @{
            var id = Model.Id.ToString();
            var requestTypeName = Model.TypeId.HasValue && Model.TypeId != 0
                ? Model.Type.Name
                : Model.Others;
            var  severityId = Model.SeverityId.HasValue && Model.SeverityId > 0
                ? Model.SeverityId.Value
                : 0;
            var severityName = severityId > 0
                ? RequestSeverityEnum.DisplayName(severityId)
                : "N/A";
            var dateRequest = Model.DateRequest.HasValue
                ? Model.DateRequest.Value.ToString("MMMM dd, yyyy hh:mm tt")
                : "N/A";
            var dateReceived = Model.DateRecieved.HasValue
                ? Model.DateRecieved.Value.ToString("MMMM dd, yyyy hh:mm tt")
                : "N/A";
            var description = !string.IsNullOrWhiteSpace(Model.Description)
                ? Model.Description.Trim()
                : "N/A";
        }
        @* Request Information *@
        <section class="tsr-detail-section">
            <div class="tsr-detail-section-header">
                <h4 class="section-heading-title text-primary">
                    <i class="glyphicon glyphicon-file"></i>
                    REQUEST INFORMATION
                </h4>
            </div>

            <div class="tsr-detail-grid tsr-detail-grid-2">
                @* Request Type *@
                <div class="tsr-detail-item">
                    <p class="tsr-detail-label light-text">TYPE</p>
                    <p class="tsr-detail-value">@requestTypeName</p>
                </div>

                @* Severity *@
                <div class="tsr-detail-item">
                    <p class="tsr-detail-label light-text">SEVERITY</p>
                    <div class="tsr-detail-inline-actions flex-row flex-child-center-h flex-space-between flex-wrap">
                        <p id="severity_container" class="tsr-inline-content">
                            @if (severityId > 0)
                            {
                                <span class="@getSeverityLabelClass(severityId)">
                                    @severityName
                                </span>
                            }
                            else
                            {
                                <span class="label label-default">N/A</span>
                            }
                        </p>

                        @if (isIT && !isImmutable)
                        {
                            Html.RenderPartial("~/Views/Request/Partial/_UpdateSeverityModal.cshtml");
                            <button type="button"
                                    id="update_severity_button"
                                    class="btn btn-link btn-xs" `
                                    data-toggle="modal"
                                    data-target="#update_severity_modal">
                                Update
                            </button>
                        }
                    </div>
                </div>

                @* Date Request *@
                <div class="detail-item">
                    <p class="tsr-detail-label light-text">DATE REQUESTED</p>
                    <p class="tsr-detail-value wrap-text">
                        @dateRequest
                    </p>
                </div>

                @* Date Received *@
                <div class="detail-item">
                    <p class="tsr-detail-label light-text">DATE RECEIVED</p>
                    <p class="tsr-detail-value wrap-text">
                        @dateReceived
                    </p>
                </div>

                @* Description *@
                <div class="tsr-detail-item tsr-detail-item-full">
                    <div class="flex-row">
                        <p class="tsr-detail-label light-text">DESCRIPTION</p>

                        @if (isEditable)
                        {
                            <button type="button" class="edit-description-button btn-link unset-button" data-toggle="modal" data-target="#edit_description_modal">
                                (<p class="text-success inline bold-text">
                                    Update
                                </p>)
                            </button>

                            @Html.Partial("~/Views/Request/Partial/_EditDescriptionModal.cshtml", Model);
                        }

                    </div>

                    <p id="technical_service_request_description_container" class="tsr-detail-value wrap-text light-text">
                        @description
                    </p>
                </div>

                @* Equipment Detail *@
                @if (isEquipmentRepairTroubleshootingService && hasEquipmentDetails)
                {
                    <div class="tsr-detail-item tsr-detail-item-full">
                        <p class="tsr-detail-label light-text"><i class="glyphicon glyphicon-cog"></i> EQUIPMENT</p>

                        <div class="row tsr-schedule-wrap">
                            <div class="col-sm-4 col-xs-12 tsr-schedule-item">
                                <p class="tsr-schedule-item-label">ASSET TAG</p>
                                <p class="tsr-schedule-item-value">@(Model.EquipmentAssetTag ?? "N/A")</p>
                            </div>

                            <div class="col-sm-4 col-xs-12 tsr-schedule-item">
                                <p class="tsr-schedule-item-label">MODEL</p>
                                <p class="tsr-schedule-item-value">@(Model.EquipmentModel ?? "N/A")</p>
                            </div>

                            <div class="col-sm-4 col-xs-12 tsr-schedule-item">
                                <p class="tsr-schedule-item-label">TYPE</p>
                                <p class="tsr-schedule-item-value">@(Model.EquipmentTypeName ?? "N/A")</p>
                            </div>
                        </div>
                    </div>
                }


                @* Schedule *@
                @if (isScheduledService && hasScheduleDetails)
                {
                    <div class="tsr-detail-item tsr-detail-item-full">
                        <p class="tsr-detail-label light-text"><i class="glyphicon glyphicon-calendar"></i> SCHEDULE</p>

                        <div class="row tsr-schedule-wrap">
                            <div class="col-sm-4 col-xs-12 tsr-schedule-item">
                                <p class="tsr-schedule-item-label">DATE</p>
                                <p class="tsr-schedule-item-value">@Model.ScheduledDate.Value.ToString("MMMM dd, yyyy")</p>
                            </div>

                            <div class="col-sm-4 col-xs-12 tsr-schedule-item">
                                <p class="tsr-schedule-item-label">START</p>
                                <p class="tsr-schedule-item-value">@DateTime.Today.Date.Add(Model.ScheduledStartTime.Value).ToString("hh:mm tt")</p>
                            </div>

                            <div class="col-sm-4 col-xs-12 tsr-schedule-item">
                                <p class="tsr-schedule-item-label">END</p>
                                <p class="tsr-schedule-item-value">@DateTime.Today.Date.Add(Model.ScheduledEndTime.Value).ToString("hh:mm tt")</p>
                            </div>
                        </div>
                    </div>
                }

            </div>

        </section>

        @{ var historyCount = Model.RequestHistories.Count(); }

        @* Action History *@
        <section class="tsr-detail-section">
            <div class="flex-row flex-wrap flex-child-center-h flex-space-between detail-history-heading-row">
                <h4 class="section-heading-title text-primary">
                    <i class="glyphicon glyphicon-cog"></i>
                    ACTION HISTORY
                </h4>

                @if (isIT && !isImmutable)
                {
                    Html.RenderPartial("~/Views/Request/Partial/_AddActionHistoryModal.cshtml");
                    <button id="add_action_history_button"
                            class="btn btn-default"
                            type="button"
                            data-toggle="modal"
                            data-target="#add_action_history_modal">
                        <i class="glyphicon glyphicon-plus"></i>
                        Add
                    </button>
                }
            </div>

            <section class="action-history-table-container table-responsive">
                <table id="action_history_table" class="table table-bordered table-condensed action-history-table">
                    <tbody>
                        @if (historyCount > 0)
                        {
                            foreach (var history in Model.RequestHistories)
                            {
                                Html.RenderPartial("~/Views/Request/Partial/_ActionHistoryRow.cshtml", history);
                            }
                        }
                        else
                        {
                            <tr class="action-history-empty-row">
                                <td class="text-primary light-text text-center">No Action History Available.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </section>
        </section>

        @if (isCancellable && isStandard)
        {
            <section class="flex-row-reverse detail-cancel-row">
                <button id="cancel_request_button"
                        class="btn btn-danger center-child"
                        type="button"
                        data-request-id="@id">
                    <i class="glyphicon glyphicon glyphicon-remove"></i>
                    Cancel
                </button>
            </section>
        }

    </section>
    </section>

</section>

@section Scripts {
    <script>
        const currentTechnicalServiceRequestId = parseInt("@Model.Id", 10);

        const updateSeverityUrl = "@Url.Action("UpdateSeverity", "Request")";
        const cancelRequestUrl = "@Url.Action("CancelRequest", "Request")";
        const actionHistoryRowUrl = "@Url.Action("GetTechnicalServiceRequestActionHistory", "RequestHistory")";
        const formGenerationStateUrl = "@Url.Action("GetFormGenerationState", "Request")";
    </script>

    <script src="~/Scripts/App/Request/CancelRequest.js" defer></script>
    <script src="~/Scripts/App/Request/UpdateSeverity.js" defer></script>
    <script src="~/Scripts/App/Request/LiveReloadDetailsInfo.js" defer></script>
    <script src="~/Scripts/App/Request/LiveReloadDetailsActionHistory.js" defer></script>
}
