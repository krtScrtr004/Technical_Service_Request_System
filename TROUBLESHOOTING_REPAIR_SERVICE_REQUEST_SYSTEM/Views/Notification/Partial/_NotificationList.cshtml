@model IEnumerable<TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Models.NotificationDetailViewModels>
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Utilities

@if (Model.Count() > 0)
{
    foreach (var notification in Model)
    {
        var isReadClass = notification.IsRead ? "bg-light" : "";

        var id = notification.Id.ToString();
        var title = notification.Title.Trim();
        var message = notification.Message.Trim();
        var isRead = notification.IsRead ? "true" : "false";
        var createdAt = notification.CreatedAt.ToString("MMMM dd yyyy, hh:mm tt");

        <button class="unset-button notification-box-container js-open-notification-detail" type="button"
                data-id="@id"
                data-title="@title"
                data-message="@message"
                data-is-read="@isRead"
                data-created-at="@createdAt">
            <div class="notification-box well flex-col @isReadClass">
                <h4 class="title single-line-ellipsis text-primary bold-text" title="@title">
                    @title
                </h4>

                <hr class="bg-default" />

                <div class="notification-content-row flex-row flex-wrap flex-space-between">
                    <p class="message light-text multi-line-ellipsis-2 text-primary" title="@message">
                        @message
                    </p>

                    <p class="date light-text text-right">
                        @createdAt
                    </p>
                </div>
            </div>

        </button>
    }
}
else
{
    <div class="flex-col flex-child-center-v flex-1 flex-child-center-h">
        <h1 class="text-primary">
            <i class="glyphicon glyphicon-inbox"></i>
        </h1>
        <h5 class="text-primary text-center light-text">
            You have no notifications
        </h5>
    </div>
}

