@model TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Models.EquipmentDetailsViewModel
@using System.Linq
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Core
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Enumerables
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Utilities

@{
    ViewBag.Title = "Details";

    var currentUser = ViewBag.CurrentUser as UserSession;
    var currentUserPrivilegeIds = currentUser.PrivilegeIds;
    var isAdmin = AccountTypeEnum.IsAdmin(currentUserPrivilegeIds);
    var isIT = AccountTypeEnum.IsIT(currentUserPrivilegeIds);

    var assetTagInitials = string.IsNullOrWhiteSpace(Model.AssetTag)
        ? "EQ"
        : new string(Model.AssetTag.Trim().Take(2).ToArray()).ToUpperInvariant();

    var typeName = Model.EquipmentTypeId > 0
        ? EquipmentTypeEnum.DisplayName(Model.EquipmentTypeId)
        : "N/A";
    var statusName = Model.EquipmentStatusId > 0
        ? EquipmentStatusEnum.DisplayName(Model.EquipmentStatusId)
        : "N/A";

    var createdBy = GeneralUtilities.CreateFullName(
        Model.CreatedByRegistrationFirstName,
        Model.CreatedByRegistrationLastName,
        Model.CreatedByRegistrationMiddleName,
        Model.CreatedByRegistrationExtensionName
    ).ToUpperInvariant();
    if (string.IsNullOrWhiteSpace(createdBy))
    {
        createdBy = "N/A";
    }
}

@section Styles {
    <link rel="stylesheet" href="~/Content/App/Equipment/Details.css" type="text/css" />
}

<section class="center-child equipment-details-page">
    <div class="panel panel-default content-panel bg-light">

        <section class="panel-heading profile-header flex-row flex-space-between flex-child-center-h">
            <div class="profile-main flex-row flex-child-center-h">

                <div>
                    @* Asset Tag / Model *@
                    <div class="profile-title-row flex-row flex-child-center-h flex-wrap">
                        <h4 class="profile-name">
                            <span class="asset-tag">@Model.AssetTag</span> - <span class="equipment-model">@Model.EquipmentModel</span>
                        </h4>

                        @* Id *@
                        <span class="registration-id-chip light-text">ID: @Model.Id</span>
                    </div>

                </div>
            </div>
        </section>  

        <section class="panel-body">
            <section class="details-section">
                <div class="section-header">
                    <h4 class="text-primary">
                        <i class="glyphicon glyphicon-info-sign"></i>
                        GENERAL INFORMATION
                    </h4>
                </div>

                <div class="detail-grid detail-grid-3">
                    @* Asset Tage *@
                    <div class="detail-item">
                        <p class="detail-label">ASSET TAG</p>
                        <p class="asset-tag detail-value">@(string.IsNullOrWhiteSpace(Model.AssetTag) ? "N/A" : Model.AssetTag)</p>
                    </div>
                    
                    @* Model *@
                    <div class="detail-item">
                        <p class="detail-label">MODEL</p>
                        <p class="equipment-model detail-value">@(string.IsNullOrWhiteSpace(Model.EquipmentModel) ? "N/A" : Model.EquipmentModel)</p>
                    </div>

                    @* Type *@
                    <div class="detail-item">
                        <p class="detail-label">TYPE</p>
                        <p class="equipment-type detail-value">@typeName</p>
                    </div>
                </div>
            </section>

            <section class="details-section">
                <div class="section-header">
                    <h4 class="text-primary">
                        <i class="glyphicon glyphicon-map-marker"></i>
                        LOCATION INFORMATION
                    </h4>
                </div>

                <div class="detail-grid detail-grid-3">
                    @* Building Number *@
                    <div class="detail-item">
                        <p class="detail-label">BUILDING NUMBER</p>
                        <p class="building-number detail-value">@(Model.BuildingNumber.HasValue ? Model.BuildingNumber.Value.ToString() : "N/A")</p>
                    </div>

                    @* Floor Number *@
                    <div class="detail-item">
                        <p class="detail-label">FLOOR NUMBER</p>
                        <p class="floor-number detail-value">@(Model.FloorNumber.HasValue ? Model.FloorNumber.Value.ToString() : "N/A")</p>
                    </div>

                    @* Office *@
                    <div class="detail-item">
                        <p class="detail-label">OFFICE</p>
                        <p class="office detail-value">@(string.IsNullOrWhiteSpace(Model.Office) ? "N/A" : Model.Office)</p>
                    </div>
                </div>
            </section>

            <section class="details-section">
                <div class="section-header">
                    <h4 class="text-primary">
                        <i class="glyphicon glyphicon-file"></i>
                        RECORD INFORMATION
                    </h4>
                </div>

                <div class="detail-grid detail-grid-2">
                    @* Status *@
                    <div class="detail-item">
                        <p class="detail-label">STATUS</p>
                        <p class="equipment-status detail-value">@statusName</p>
                    </div>

                    @* Repair Count *@
                    <div class="detail-item">
                        <p class="detail-label">REPAIR COUNT</p>
                        <p class="repair-count detail-value">@Model.RepairCount</p>
                    </div>

                    @* Created By *@
                    <div class="detail-item">
                        <p class="detail-label">CREATED BY</p>
                        <p class="detail-value">@createdBy</p>
                    </div>
                </div>
            </section>
        </section>

        @if (isAdmin || isIT)
                {
            // EditorExtensions Button
            <section class="panel-footer management-buttons-container">
                <p class="text-primary options-label light-text text-right bold-text">More Options</p>

                <div class="buttons-container flex-row flex-child-end-v">
                    <a class="btn btn-warning" href="@Url.Action("Edit", "Equipment", new { id = Model.Id })">
                        <i class="glyphicon glyphicon-pencil"></i>
                        EDIT EQUIPMENT
                    </a>
                </div>
            </section>
        }
    </div>
</section>

@section Scripts {
    <script>
        const currentEquipmentId = parseInt("@Model.Id", 10);
    </script>
    <script src="~/Scripts/App/Equipment/LiveReloadDetailsInfo.js" defer></script>
}
