@model TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Models.TechnicalServiceRequestDetailsViewModel
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Enumerables;
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Utilities;
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Core;

@{
    ViewBag.Title = "Details";

    var currentUser = ViewBag.CurrentUser as UserSession;
    var userAccountType = currentUser.PrivilegeIds;

    var isStandard = AccountTypeEnum.IsStandard(userAccountType);
    var isAdmin = AccountTypeEnum.IsAdmin(userAccountType);
    var isIT = AccountTypeEnum.IsIT(userAccountType);

    var currentStatus = Model.TechnicalServiceRequestStatusId;

    var isQueued = ViewBag.IsQueued as bool? ?? false;

    var isFormGeneratable = currentStatus == (int)TechnicalServiceRequestStatusEnum.RESOLVED ||
        currentStatus == (int)TechnicalServiceRequestStatusEnum.CLOSED;
    var formLink = isFormGeneratable ?
        Url.Action("Form", "TechnicalServiceRequests", new { id = Model.TechnicalServiceRequestFormGeneratableHistoryId })
        : "#";

    var isOwnRequest = Model.ClientRegistrationId == currentUser.Id;
    var isEditable = isStandard && isOwnRequest &&
        (currentStatus == (int)TechnicalServiceRequestStatusEnum.PENDING ||
        currentStatus == (int)TechnicalServiceRequestStatusEnum.OPEN);

    var isImmutable = currentStatus == (int)TechnicalServiceRequestStatusEnum.CANCELLED ||
        currentStatus == (int)TechnicalServiceRequestStatusEnum.CLOSED;
    var isCancellable = TechnicalServiceRequestStatusEnum
        .GetCancellableStatusIds()
        .Any(s => s == currentStatus);

    var isEquipmentRepairTroubleshootingService = Model.TechnicalServiceTypeId.GetValueOrDefault() == (int)TechnicalServiceTypeEnum.EQUIPMENT_REPAIR_TROUBLESHOOTING;
    var isScheduledService = TechnicalServiceTypeEnum.IsScheduleControlProcessRequest(Model.TechnicalServiceTypeId.GetValueOrDefault());

    Func<int, string> getStatusLabelClass = (status) =>
    {
        switch (status)
        {
            case TechnicalServiceRequestStatusEnum.PENDING:
                return "label label-warning status-label";
            case TechnicalServiceRequestStatusEnum.OPEN:
                return "label label-primary status-label";
            case TechnicalServiceRequestStatusEnum.ONGOING:
                return "label label-info status-label";
            case TechnicalServiceRequestStatusEnum.RESOLVED:
                return "label label-success status-label";
            case TechnicalServiceRequestStatusEnum.CANCELLED:
                return "label label-danger status-label";
            case TechnicalServiceRequestStatusEnum.CLOSED:
                return "label label-default status-label";
            default:
                return "label label-default status-label";
        }
    };

    Func<int, string> getSeverityLabelClass = (severity) =>
    {
        switch (severity)
        {
            case TechnicalServicRequestSeverityEnum.LOW:
                return "label label-success";
            case TechnicalServicRequestSeverityEnum.MEDIUM:
                return "label label-warning";
            case TechnicalServicRequestSeverityEnum.HIGH:
            case TechnicalServicRequestSeverityEnum.CRITICAL:
                return "label label-danger";
            default:
                return "label label-default";
        }
    };

    var requestTypeName =
        (Model.TechnicalServiceTypeId.HasValue && Model.TechnicalServiceTypeId != 0)
            ? Model.TechnicalServiceType.TechnicalServiceTypeName
            : Model.Others;
}

@section Styles {
    <link rel="stylesheet" href="~/Content/App/TechnicalServiceRequest/Details.css" />
}

@Html.AntiForgeryToken()

<section class="container tsr-detail-page-container">
    <section class="panel panel-default tsr-content-panel">

        @* Heading *@
        <section class="panel-heading tsr-page-header flex-row flex-child-center-h flex-space-between flex-wrap">
            <div class="tsr-page-header-main">
                <p class="tsr-ref-code text-primary">REFERENCE CODE: @Model.ReferenceCode</p>

                <div id="status_container" class="tsr-page-status">
                    <span class="@getStatusLabelClass(Model.TechnicalServiceRequestStatusId)">
                        @TechnicalServiceRequestStatusEnum.DisplayName(Model.TechnicalServiceRequestStatusId)
                    </span>
                </div>
            </div>

            <div class="tsr-page-actions flex-row flex-wrap">
                <a id="generate_tsrf_button" class="btn btn-success @(isFormGeneratable ? "block" : "no-display")" href="@formLink">
                    <i class="glyphicon glyphicon-file"></i>
                    Generate TSRF
                </a>

                @*@if (isAdmin && isQueued)
                    {
                        <button type="button" class="btn btn-primary">
                            <i class="glyphicon glyphicon-user"></i>
                            Assign IT
                        </button>
                    }*@
            </div>
        </section>

        @* Body *@
        <section class="panel-body tsr-page-body">

            @* Client Information *@
            <section class="tsr-detail-section">
                <div class="tsr-detail-section-header">
                    <h4 class="section-heading-title text-primary">
                        <i class="glyphicon glyphicon-user"></i>
                        CLIENT INFORMATION
                    </h4>
                </div>

                <div class="tsr-detail-grid tsr-detail-grid-3">
                    <div class="tsr-detail-item">
                        <p class="tsr-detail-label light-text">LAST NAME</p>
                        <p class="tsr-detail-value">@Model.ClientLastName</p>
                    </div>

                    <div class="tsr-detail-item">
                        <p class="tsr-detail-label light-text">FIRST NAME</p>
                        <p class="tsr-detail-value">@Model.ClientFirstName</p>
                    </div>

                    <div class="tsr-detail-item">
                        <p class="tsr-detail-label light-text">MIDDLE NAME</p>
                        <p class="tsr-detail-value">@(Model.ClientMiddleName ?? "N/A")</p>
                    </div>

                    <div class="tsr-detail-item">
                        <p class="tsr-detail-label light-text">EXT. NAME</p>
                        <p class="tsr-detail-value">@(Model.ClientExtensionName ?? "N/A")</p>
                    </div>

                    <div class="tsr-detail-item">
                        <p class="tsr-detail-label light-text"><i class="glyphicon glyphicon-envelope"></i> EMAIL</p>
                        <p class="tsr-detail-value">@(string.IsNullOrWhiteSpace(Model.ClientEmailAddress) ? "N/A" : Model.ClientEmailAddress)</p>
                    </div>

                    <div class="tsr-detail-item">
                        <p class="tsr-detail-label light-text"><i class="glyphicon glyphicon-earphone"></i> CONTACT NUMBER</p>
                        <p class="tsr-detail-value">@(string.IsNullOrWhiteSpace(Model.ClientContactNumber) ? "N/A" : Model.ClientContactNumber)</p>
                    </div>

                    <div class="tsr-detail-item">
                        <p class="tsr-detail-label light-text">OFFICE</p>
                        <p class="tsr-detail-value">@(string.IsNullOrWhiteSpace(Model.ClientOffice) ? "N/A" : Model.ClientOffice)</p>
                    </div>

                    <div class="tsr-detail-item">
                        <p class="tsr-detail-label light-text">POSITION</p>
                        <p class="tsr-detail-value">@(string.IsNullOrWhiteSpace(Model.ClientPosition) ? "N/A" : Model.ClientPosition)</p>
                    </div>
                </div>
            </section>

            @* Request Information *@
            <section class="tsr-detail-section">
                <div class="tsr-detail-section-header">
                    <h4 class="section-heading-title text-primary">
                        <i class="glyphicon glyphicon-file"></i>
                        REQUEST INFORMATION
                    </h4>
                </div>

                <div class="tsr-detail-grid tsr-detail-grid-2">
                    @* Request Type *@
                    <div class="tsr-detail-item">
                        <p class="tsr-detail-label light-text">TYPE</p>
                        <p class="tsr-detail-value">@(string.IsNullOrWhiteSpace(requestTypeName) ? "N/A" : requestTypeName)</p>
                    </div>

                    @* Severity *@
                    <div class="tsr-detail-item">
                        <p class="tsr-detail-label light-text">SEVERITY</p>
                        <div class="tsr-detail-inline-actions flex-row flex-child-center-h flex-space-between flex-wrap">
                            <p id="severity_container" class="tsr-inline-content">
                                @if (Model.TechnicalServiceRequestSeverityId.HasValue && Model.TechnicalServiceRequestSeverityId > 0)
                                {
                                    <span class="@getSeverityLabelClass(Model.TechnicalServiceRequestSeverityId.Value)">
                                        @Model.TechnicalServiceRequestSeverity.SeverityName
                                    </span>
                                }
                                else
                                {
                                    <span class="label label-default">N/A</span>
                                }
                            </p>

                            @if (isIT && !isImmutable)
                            {
                                Html.RenderPartial("~/Views/TechnicalServiceRequests/Partial/_UpdateSeverityModal.cshtml");
                                <button type="button"
                                        id="update_severity_button"
                                        class="btn btn-link btn-xs" `
                                        data-toggle="modal"
                                        data-target="#update_severity_modal">
                                    Update
                                </button>
                            }
                        </div>
                    </div>

                    @* Date Request *@
                    <div class="detail-item">
                        <p class="tsr-detail-label light-text">DATE REQUESTED</p>
                        <p class="tsr-detail-value wrap-text">
                            @(Model.DateRequest.HasValue
                                 ? Model.DateRequest.Value.ToString("MMMM dd, yyyy hh:mm tt")
                                 : "N/A")
                        </p>
                    </div>

                    @* Date Received *@
                    <div class="detail-item">
                        <p class="tsr-detail-label light-text">DATE RECEIVED</p>
                        <p class="tsr-detail-value wrap-text">
                            @(Model.DateRecieved.HasValue
                                  ? Model.DateRecieved.Value.ToString("MMMM dd, yyyy hh:mm tt")
                                  : "N/A")
                        </p>
                    </div>

                    @* Description *@
                    <div class="tsr-detail-item tsr-detail-item-full">
                        <div class="flex-row">
                            <p class="tsr-detail-label light-text">DESCRIPTION</p>

                            @if (isEditable)
                            {
                                <button type="button" class="edit-description-button btn-link unset-button" data-toggle="modal" data-target="#edit_description_modal">
                                    (<p class="text-success inline bold-text">
                                        Update
                                    </p>)
                                </button>

                                @Html.Partial("~/Views/TechnicalServiceRequests/Partial/_EditDescriptionModal.cshtml", Model);
                            }

                        </div>

                        <p id="technical_service_request_description_container" class="tsr-detail-value wrap-text light-text">
                            @(string.IsNullOrWhiteSpace(Model.TechnicalServiceRequestDescription)
                                 ? "N/A"
                                 : Model.TechnicalServiceRequestDescription)
                        </p>
                    </div>

                    @* Equipment Detail *@
                    @if (isEquipmentRepairTroubleshootingService &&
                        (!string.IsNullOrEmpty(Model.TechnicalServiceRequestEquipmentModel) ||
                        !string.IsNullOrEmpty(Model.TechnicalServiceRequestEquipmentAssetTag) ||
                        !string.IsNullOrEmpty(Model.TechnicalServiceRequestEquipmentTypeName)))
                    {
                        <div class="tsr-detail-item tsr-detail-item-full">
                            <p class="tsr-detail-label light-text"><i class="glyphicon glyphicon-cog"></i> EQUIPMENT</p>

                            <div class="row tsr-schedule-wrap">
                                <div class="col-sm-4 col-xs-12 tsr-schedule-item">
                                    <p class="tsr-schedule-item-label">ASSET TAG</p>
                                    <p class="tsr-schedule-item-value">@(Model.TechnicalServiceRequestEquipmentAssetTag ?? "N/A")</p>
                                </div>

                                <div class="col-sm-4 col-xs-12 tsr-schedule-item">
                                    <p class="tsr-schedule-item-label">MODEL</p>
                                    <p class="tsr-schedule-item-value">@(Model.TechnicalServiceRequestEquipmentModel ?? "N/A")</p>
                                </div>

                                <div class="col-sm-4 col-xs-12 tsr-schedule-item">
                                    <p class="tsr-schedule-item-label">TYPE</p>
                                    <p class="tsr-schedule-item-value">@(Model.TechnicalServiceRequestEquipmentTypeName ?? "N/A")</p>
                                </div>
                            </div>
                        </div>
                    }


                    @* Schedule *@
                    @if (isScheduledService &&
                        Model.TechnicalServiceRequestScheduledDate.HasValue &&
                        Model.TechnicalServiceRequestScheduledStartTime.HasValue &&
                        Model.TechnicalServiceRequestScheduledEndTime.HasValue)
                    {
                        <div class="tsr-detail-item tsr-detail-item-full">
                            <p class="tsr-detail-label light-text"><i class="glyphicon glyphicon-calendar"></i> SCHEDULE</p>

                            <div class="row tsr-schedule-wrap">
                                <div class="col-sm-4 col-xs-12 tsr-schedule-item">
                                    <p class="tsr-schedule-item-label">DATE</p>
                                    <p class="tsr-schedule-item-value">@Model.TechnicalServiceRequestScheduledDate.Value.ToString("MMMM dd, yyyy")</p>
                                </div>

                                <div class="col-sm-4 col-xs-12 tsr-schedule-item">
                                    <p class="tsr-schedule-item-label">START</p>
                                    <p class="tsr-schedule-item-value">@DateTime.Today.Date.Add(Model.TechnicalServiceRequestScheduledStartTime.Value).ToString("hh:mm tt")</p>
                                </div>

                                <div class="col-sm-4 col-xs-12 tsr-schedule-item">
                                    <p class="tsr-schedule-item-label">END</p>
                                    <p class="tsr-schedule-item-value">@DateTime.Today.Date.Add(Model.TechnicalServiceRequestScheduledEndTime.Value).ToString("hh:mm tt")</p>
                                </div>
                            </div>
                        </div>
                    }

                </div>

            </section>

            @* Action History *@
            <section class="tsr-detail-section">
                <div class="flex-row flex-wrap flex-child-center-h flex-space-between detail-history-heading-row">
                    <h4 class="section-heading-title text-primary">
                        <i class="glyphicon glyphicon-cog"></i>
                        ACTION HISTORY
                    </h4>

                    @if (isIT && !isImmutable)
                    {
                        Html.RenderPartial("~/Views/TechnicalServiceRequests/Partial/_AddActionHistoryModal.cshtml");
                        <button id="add_action_history_button"
                                class="btn btn-default"
                                type="button"
                                data-toggle="modal"
                                data-target="#add_action_history_modal">
                            <i class="glyphicon glyphicon-plus"></i>
                            Add
                        </button>
                    }
                </div>

                <section class="action-history-table-container table-responsive">
                    <table id="action_history_table" class="table table-bordered table-condensed action-history-table">
                        <tbody>
                            @if (Model.TechnicalServiceRequestHistories.Count() > 0)
                            {
                                foreach (var history in Model.TechnicalServiceRequestHistories)
                                {
                                    Html.RenderPartial("~/Views/TechnicalServiceRequests/Partial/_ActionHistoryRow.cshtml", history);
                                }
                            }
                            else
                            {
                                <tr class="action-history-empty-row">
                                    <td class="text-primary light-text text-center">No Action History Available.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </section>
            </section>

            @if (isCancellable && AccountTypeEnum.IsStandard(currentUser.PrivilegeIds))
            {
                <section class="flex-row-reverse detail-cancel-row">
                    <button id="cancel_request_button"
                            class="btn btn-danger center-child"
                            type="button"
                            data-request-id="@Model.Id">
                        <i class="glyphicon glyphicon glyphicon-remove"></i>
                        Cancel
                    </button>
                </section>
            }

        </section>
    </section>

</section>

@section Scripts {
    <script>
        const currentTechnicalServiceRequestId = @Model.Id;
        const updateSeverityUrl = "@Url.Action("UpdateSeverity", "TechnicalServiceRequests")";
        const cancelRequestUrl = "@Url.Action("CancelRequest", "TechnicalServiceRequests")";
        const actionHistoryRowUrl = "@Url.Action("GetTechnicalServiceRequestActionHistory", "TechnicalServiceRequestHistory")";
        const formGenerationStateUrl = "@Url.Action("GetFormGenerationState", "TechnicalServiceRequests")";
    </script>

    <script src="~/Scripts/App/TechnicalServiceRequest/CancelRequest.js" defer></script>
    <script src="~/Scripts/App/TechnicalServiceRequest/UpdateSeverity.js" defer></script>
    <script src="~/Scripts/App/TechnicalServiceRequest/LiveReloadDetailsInfo.js" defer></script>
    <script src="~/Scripts/App/TechnicalServiceRequest/LiveReloadDetailsActionHistory.js" defer></script>
}
