@model TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Models.TechnicalServiceRequestHistory
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Enumerables

@{
    Func<int, string> getStatusLabelClass = (status) =>
    {
        switch (status)
        {
            case TechnicalServiceRequestStatusEnum.PENDING:
                return "label label-warning status-label";
            case TechnicalServiceRequestStatusEnum.OPEN:
                return "label label-primary status-label";
            case TechnicalServiceRequestStatusEnum.ONGOING:
                return "label label-info status-label";
            case TechnicalServiceRequestStatusEnum.RESOLVED:
                return "label label-success status-label";
            case TechnicalServiceRequestStatusEnum.CANCELLED:
                return "label label-danger status-label";
            case TechnicalServiceRequestStatusEnum.CLOSED:
                return "label label-default status-label";
            default:
                return "label label-default status-label";
        }
    };

    var fullName = string.Join(" ", new[]
    {
        Model.ActionTakenByRegistration.LastName + ",",
        Model.ActionTakenByRegistration.FirstName,
        Model.ActionTakenByRegistration.MiddleName
    }.Where(x => !string.IsNullOrWhiteSpace(x)));
}

<tr class="action-history-row">
    <td colspan="4" class="action-history-entry-cell">
        <div class="panel panel-default action-history-entry-panel">
            <div class="panel-body action-history-entry-body">
                <div class="row action-history-meta-row">
                    <div class="col-sm-5 col-xs-12 action-history-meta-item">
                        <p class="action-history-label light-text">TAKEN BY</p>
                        <p class="action-history-value">@(string.IsNullOrWhiteSpace(fullName) ? "N/A" : fullName)
                        </p>
                    </div>

                    <div class="col-sm-4 col-xs-12 action-history-meta-item">
                        <p class="action-history-label">DATE</p>
                        <p class="action-history-value">
                            @(Model.DateAction.HasValue
                                ? Model.DateAction.Value.ToString("MMMM dd, yyyy hh:mm tt")
                                : "N/A")
                        </p>
                    </div>

                    <div class="col-sm-3 col-xs-12 action-history-meta-item">
                        <p class="action-history-label">STATUS</p>
                        @if (Model.TechnicalServiceRequestStatusId.HasValue && Model.TechnicalServiceRequestStatusId > 0)
                        {
                            <span class="@getStatusLabelClass(Model.TechnicalServiceRequestStatusId.Value)">
                                @Model.TechnicalServiceRequestStatus.TechnicalServiceRequestStatusName
                            </span>
                        }
                        else
                        {
                            <span class="label label-default">N/A</span>
                        }
                    </div>
                </div>

                <div class="action-history-divider"></div>

                <div class="action-history-action-wrap">
                    <p class="action-history-label">ACTION TAKEN</p>
                    <p class="action-taken-text wrap-text">
                        @(string.IsNullOrWhiteSpace(Model.ActionTaken)
                            ? "N/A"
                            : Model.ActionTaken)
                    </p>
                </div>
            </div>
        </div>
    </td>
</tr>
