<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - TSR SYSTEM</title>

    <link rel="icon" type="image/x-icon" href="~/Content/Images/logo.png" />

    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    @RenderSection("Styles", required: false)

    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.10.0/css/bootstrap-datepicker.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-datepicker/1.10.0/css/bootstrap-datepicker.min.css" rel="stylesheet" />

</head>

<body class="flex-col">
    @if (Request.IsAuthenticated)
    {
        @Html.Action("Header", "Layout");
    }

    <main>
        @RenderBody()
    </main>

    <footer class="container body-content">
        <hr class="bg-default" />
        <p>&copy; @DateTime.Now.Year - Technical Service Request System</p>
    </footer>

    @* jQuery and Bootstrap JS *@
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")

    @* SweetAlert2 *@
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @Html.Partial("~/Views/Shared/_AlertModal.cshtml");

    @* Data Tables *@
    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>

    @* SignalR *@
    <script src="~/Scripts/jquery.signalR-2.4.3.min.js"></script>
    <script src="~/signalr/hubs"></script>

    @if (Request.IsAuthenticated)
    {
        <script>
            const notificationBadgeUrl = "@Url.Action("HeaderNotificationBadge", "Notification")";
        </script>
        <script src="~/Scripts/App/Notification/LiveReloadNotificationBadge.js" defer></script>
    }

    @RenderSection("Scripts", required: false)
</body>
</html>

