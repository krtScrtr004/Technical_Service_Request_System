@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Utilities;

@{
    var alertModal = TempData["alertModal"] as AlertModalUtility;
}


@if (alertModal != null)
{
    <script>
        var alertModalData = @Html.Raw(Json.Encode(alertModal))

        Swal.fire({
            title: alertModalData.Title,
            text: alertModalData.Message,
            icon: alertModalData.Status,
            confirmButtonText: 'OK',
            width: "600px"
        });
    </script>
}
