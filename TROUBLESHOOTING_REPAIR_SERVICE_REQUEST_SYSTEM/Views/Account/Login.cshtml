@model TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Models.LoginViewModel

@{ ViewBag.Title = "Log in"; }

@section Styles
{
    <link rel="stylesheet" href="~/Content/App/Account/Login.css" type="text/css" />
}

<section class="container-fluid login-page center-child">
    <section class="row login-page-row">
        <section class="login-header flex-col flex-child-center-h flex-child-center-v">
            <img src="~/Content/Images/logo.png" class="login-logo" alt="TSR Logo" />

            <section class="login-headings">
                <h5 class="login-subheading text-center">DEPARTMENT OF HEALTH <span class="block">METRO MANILA CENTER FOR HEALTH DEVELOPMENT</span></h5>
                <h2 class="login-heading text-center">TECHNICAL SERVICE REQUEST SYSTEM</h2>
            </section>
        </section>

        <section class="col-xs-12 col-sm-10 col-sm-offset-1 col-md-6 col-md-offset-3">
            <section class="login-card center-text">
                @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }))
                {
                    @Html.AntiForgeryToken()

                    <section class="login-form-wrap center-text">
                        @if (Model != null && Model.Alert != null && Model.Alert.ContainsKey("invalidLogin"))
                        {
                            <div class="alert alert-danger login-alert">
                                @Model.Alert["invalidLogin"].Message
                            </div>
                        }

                        <div class="form-group">
                            @Html.TextBoxFor(m => m.Email, new
                            {
                                @class = "form-control login-input",
                                @placeholder = "EMAIL"
                            })
                        </div>

                        <div class="form-group">
                            @Html.PasswordFor(m => m.Password, new
                            {
                                @class = "form-control login-input",
                                @placeholder = "PASSWORD"
                            })
                        </div>

                        <div class="form-group">
                            <input type="submit" value="Log in" class="btn login-btn" />
                        </div>

                        <div class="form-group login-remember-wrap">
                            <label>
                                @Html.CheckBoxFor(m => m.RememberMe) Remember Me
                            </label>
                        </div>

                        <a href="@Url.Action("Create", "RegistrationRequest")" class="login-register-link">
                            Register as a new user
                        </a>
                    </section>
                }
            </section>
        </section>
    </section>
</section>