@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Enumerables
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Models
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Core

@{
    ViewBag.Title = "Dashboard";

    var currentUser = ViewBag.CurrentUser as AppUserSession;

    var isAdmin = AppUserRoleEnum.IsAdmin(currentUser.RoleId);
    var isIT = AppUserRoleEnum.IsIT(currentUser.RoleId);
    var isStandard = AppUserRoleEnum.IsStandard(currentUser.RoleId);
    var roleName = isAdmin
        ? "Administrator"
        : isIT ? "IT" : "Standard User";

    var firstName = currentUser.FirstName.Trim();
    var lastName = currentUser.LastName.Trim();
}

@section Styles {
    <link rel="stylesheet" href="~/Content/App/Dashboard/Index.css" type="text/css" />
}

<section class="container-fluid dashboard-page">

    @* Header *@
    <section class="dashboard-header panel panel-default">
        <section class="panel-body">
            @* Name *@
            <h3 class="text-primary dashboard-title wrap-text">Welcome, @firstName @lastName</h3>

            @* Role *@
            <p class="dashboard-subtitle wrap-text">
                Role: <span class="label label-info">@roleName</span>
            </p>
        </section>
    </section>

    @* ards *@
    <section class="dashboard-cards-row flex-row flex-wrap">
        @* Total Requests *@
        <div class="dashboard-card-col">
            <section class="panel panel-default dashboard-card">
                <section class="panel-body">
                    <p class="dashboard-card-label">Total Requests</p>
                    <h3 id="card_total_requests" class="dashboard-card-value text-primary">0</h3>
                </section>
            </section>
        </div>

        @* Active Requests *@
        <div class="dashboard-card-col">
            <section class="panel panel-default dashboard-card">
                <section class="panel-body">
                    <p class="dashboard-card-label">Active Requests</p>
                    <h3 id="card_active_requests" class="dashboard-card-value text-warning">0</h3>
                </section>
            </section>
        </div>

        @* Resolved Requests *@
        <div class="dashboard-card-col">
            <section class="panel panel-default dashboard-card">
                <section class="panel-body">
                    <p class="dashboard-card-label">Resolved Requests</p>
                    <h3 id="card_resolved_requests" class="dashboard-card-value text-success">0</h3>
                </section>
            </section>
        </div>

        @* Unread Notifications *@
        <div class="dashboard-card-col">
            <section class="panel panel-default dashboard-card">
                <section class="panel-body">
                    <p class="dashboard-card-label">Unread Notifications</p>
                    <h3 id="card_unread_notifications" class="dashboard-card-value text-danger">0</h3>
                </section>
            </section>
        </div>
    </section>

    @* Extra Values *@
    <section class="dashboard-cards-row flex-row flex-wrap">
        <div class="dashboard-card-col">
            <section class="panel panel-default dashboard-card dashboard-extra-card">
                <section class="panel-body">
                    <p id="extra_label_1" class="dashboard-card-label">-</p>
                    <h3 id="extra_value_1" class="dashboard-card-value text-primary">0</h3>
                </section>
            </section>
        </div>

        <div class="dashboard-card-col">
            <section class="panel panel-default dashboard-card dashboard-extra-card">
                <section class="panel-body">
                    <p id="extra_label_2" class="dashboard-card-label">-</p>
                    <h3 id="extra_value_2" class="dashboard-card-value text-primary">0</h3>
                </section>
            </section>
        </div>

        <div class="dashboard-card-col">
            <section class="panel panel-default dashboard-card dashboard-extra-card">
                <section class="panel-body">
                    <p id="extra_label_3" class="dashboard-card-label">-</p>
                    <h3 id="extra_value_3" class="dashboard-card-value text-primary">0</h3>
                </section>
            </section>
        </div>
    </section>

    <section class="row dashboard-chart-row">
        @* Request Status Chart *@
        <div class="col-xs-12 col-sm-12 col-md-6">
            <section class="panel panel-default dashboard-chart-panel">
                <section class="panel-heading">
                    <b>Requests by Status</b>
                </section>
                <section class="panel-body">
                    <div id="request_status_chart" class="dashboard-chart-container"></div>
                </section>
            </section>
        </div>

        @* Top Service Chart *@
        <div class="col-xs-12 col-sm-12 col-md-6">
            <section class="panel panel-default dashboard-chart-panel">
                <section class="panel-heading">
                    <b>Top Service Types</b>
                </section>
                <section class="panel-body">
                    <div id="request_type_chart" class="dashboard-chart-container"></div>
                </section>
            </section>
        </div>
    </section>

    @* Request Trend Chart *@
    <section class="row dashboard-chart-row">
        <div class="col-xs-12 col-md-12">
            <section class="panel panel-default dashboard-chart-panel">
                <section class="panel-heading">
                    <b>Request Trend (Last 6 Months)</b>
                </section>
                <section class="panel-body">
                    <div id="request_trend_chart" class="dashboard-chart-container dashboard-chart-container-lg"></div>
                </section>
            </section>
        </div>
    </section>

    <section class="panel panel-default dashboard-equipment-panel">
        <section class="panel-heading">
            <b>Top 10 Most Repaired Equipments</b>
        </section>

        <section class="panel-body">
            <div class="table-responsive">
                <table class="table table-striped dashboard-equipment-table">
                    <thead>
                        <tr>
                            <th>Asset Tag</th>
                            <th>Model</th>
                            <th>Type</th>
                            <th>Status</th>
                            <th class="repair-count text-right">Repair Count</th>
                        </tr>
                    </thead>
                    <tbody id="top_repaired_equipments_table_body">
                        <tr>
                            <td colspan="6" class="text-center text-muted">Loading...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </section>

    @* Quick Actions *@
    <section class="dashboard-quick-actions panel panel-default">
        <section class="panel-heading">
            <b>Quick Actions</b>
        </section>

        <section class="panel-body">
            <div class="dashboard-action-buttons flex-row flex-wrap">
                @if (isStandard)
                {
                    <a href="@Url.Action("Create", "Request")" class="btn btn-primary dashboard-action-btn">
                        <i class="glyphicon glyphicon-plus"></i>
                        Create Request
                    </a>
                    <a href="@Url.Action("Index", "Request")" class="btn btn-default dashboard-action-btn">
                        <i class="glyphicon glyphicon-list"></i>
                        My Requests
                    </a>
                }
                else if (isIT)
                {
                    <a href="@Url.Action("Index", "Request")" class="btn btn-primary dashboard-action-btn">
                        <i class="glyphicon glyphicon-briefcase"></i>
                        View Work Queue
                    </a>
                    <a href="@Url.Action("Manage", "ITAvailability", new { id = currentUser.Id })" class="btn btn-warning dashboard-action-btn">
                        <i class="glyphicon glyphicon-calendar"></i>
                        Manage Availability
                    </a>
                }
                else
                {
                    <a href="@Url.Action("Index", "Registration")" class="btn btn-primary dashboard-action-btn">
                        <i class="glyphicon glyphicon-user"></i>
                        Registrations
                    </a>
                    <a href="@Url.Action("Index", "User")" class="btn btn-default dashboard-action-btn">
                        <i class="glyphicon glyphicon-th-list"></i>
                        Manage Accounts
                    </a>
                    <a href="@Url.Action("Index", "Request")" class="btn btn-info dashboard-action-btn">
                        <i class="glyphicon glyphicon-stats"></i>
                        All Service Requests
                    </a>
                }
            </div>
        </section>
    </section>
</section>

@section Scripts {
    <script src="~/Content/Highcharts-11.4.5/code/highcharts.js"></script>
    <script>
        const dashboardDataUrl = '@Url.Action("GetDashboardData", "Dashboard")';
    </script>
    <script src="~/Scripts/App/Dashboard/InitializeDashboard.js" defer></script>
    <script src="~/Scripts/App/Dashboard/LiveReloadDashboard.js" defer></script>
}

