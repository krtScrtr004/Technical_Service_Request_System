@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Enumerables
@using TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Core

@{
    ViewBag.Title = "List";
    var currentUser = ViewBag.CurrentUser as UserSession;
}

@section Styles
{
    <link rel="stylesheet" href="~/Content/App/Registration/Index.css" type="text/css" />
}

<section class="container registration-index-page">
    <div class="panel panel-default">

        <section class="panel-heading">
            <strong>
                Registrations
            </strong>
        </section>

        <section class="panel-body">
            <section class="filter-selection-container">
                @* Type Filter *@
                <div class="filter-selection">
                    <label for="account_type_filter">Account Type:</label>
                    <select id="account_type_filter" class="form-control">
                        <option value="0">All</option>
                        <optgroup label="Account Type">
                            <option value="@AccountTypeEnum.ADMIN">
                                @AccountTypeEnum.DisplayName(
                                    AccountTypeEnum.ADMIN
                                )
                            </option>
                            <option value="@AccountTypeEnum.IT">
                                @AccountTypeEnum.DisplayName(
                                    AccountTypeEnum.IT
                                )
                            </option>
                            <option value="@AccountTypeEnum.STANDARD">
                                @AccountTypeEnum.DisplayName(
                                    AccountTypeEnum.STANDARD
                                )
                            </option>
                        </optgroup>
                    </select>
                </div>
            </section>

            <div class="table-responsive">
                <table id="registration_table" class="tablesort table table-striped table-bordered">

                    <thead>
                        <tr>
                            <th></th>
                            <th>
                                Full Name
                            </th>
                            <th>
                                Email Address
                            </th>
                            <th>
                                Contact Number
                            </th>
                            <th>
                                Account Type
                            </th>
                            <th>
                                Actions
                            </th>
                        </tr>
                    </thead>

                    <tbody>
                        @**@
                    </tbody>

                </table>
            </div>
        </section>

    </div>

</section>

@section Scripts {
    <script>
        const userId = "@currentUser.Id";
        const requestUrl = "@Url.Action("GetRegistrations", "Registration")";
    </script>

    <script src="~/Scripts/App/Registration/InitializeListingDataTable.js" defer></script>
}



