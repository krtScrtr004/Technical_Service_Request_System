@model TROUBLESHOOTING_REPAIR_SERVICE_REQUEST_SYSTEM.Models.RegistrationCreateViewModel

@{ 
    ViewBag.Title = "Registration Success";

    var id = Model.Registration.Id;
    var fullName = Model.Registration.FirstName.Trim() + " " +
        Model.Registration.MiddleName?.Trim() + " " +
        Model.Registration.LastName.Trim() + " " +
        Model.Registration.ExtensionName?.Trim();
    var email = Model.Registration.Email.Trim();
    var roleName = Model.Registration.Role.Name.Trim();
    var office = Model.Registration.Office.Trim().ToUpperInvariant();
    var position = Model.Registration.Position.Trim().ToUpperInvariant();
    var registrationDate = Model.Registration.RegistrationDate.HasValue
        ? Model.Registration.RegistrationDate.Value.ToString("MMMM dd, yyyy")
        : "N/A";
    var expiryDate = Model.Registration.ExpiryDate.HasValue
        ? Model.Registration.ExpiryDate.Value.ToString("MMMM dd, yyyy")
        : "N/A";
    var code = Model.Registration.Code.Trim();
}

@section Styles
{
    <link rel="stylesheet" href="~/Content/App/Registration/Success.css" type="text/css" />
}

<section class="container center-child registration-success-page">
    <div class="panel panel-primary success-panel">

        @* Heading *@
        <section class="panel-heading">
            <h3 class="panel-title">
                <i class="glyphicon glyphicon-ok-sign"></i>
                Account Registration Successful
            </h3>
        </section>

        @* Body *@
        <section class="panel-body">
            <div class="alert alert-success" role="alert">
                The account was created successfully.
            </div>

            <h4 class="center-text success-subtitle">
                ACCOUNT INFORMATION
            </h4>

            <div class="table-responsive">
                <table class="table table-bordered table-striped success-table stack-on-mobile">
                    <tbody>

                        @* Full Name *@
                        <tr>
                            <th>Full Name</th>
                            <td colspan="3">@fullName</td>
                        </tr>

                        <tr>
                            @* Email Address *@
                            <th>Email Address</th>
                            <td>@email</td>

                            @* User Type *@
                            <th>User Type</th>
                            <td>@roleName</td>
                        </tr>

                        <tr>
                            @* Office *@
                            <th>Office</th>
                            <td>@office</td>

                            @* Position *@
                            <th>Position</th>
                            <td>@position</td>
                        </tr>

                        <tr>
                            @* Registration Date *@
                            <th>Registration Date</th>
                            <td>
                                @registrationDate
                            </td>

                            @* Expiry Date *@
                            <th>Expiry Date</th>
                            <td>
                                @expiryDate
                            </td>
                        </tr>

                        <tr>
                            @* Default Password *@
                            <th>Default Password</th>
                            <td colspan="3">
                                <span class="label label-danger credential-chip">@code</span>
                            </td>
                        </tr>
                    </tbody>
                </table>

            </div>
        </section>

        @* Footer *@
        <section class="panel-footer success-footer-actions">
            <div class="text-right">
                <a href="@Url.Action("Details", "Registration", new { id = id })" class="btn btn-primary">
                    Done
                </a>
            </div>
        </section>

    </div>
</section>

